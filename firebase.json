{
  "hosting": {
    "public": "dist",
    "predeploy": "node scripts/check-env.mjs",
    "ignore": ["firebase.json", "**/node_modules/**"],
    "headers": [
      {
        "source": "/.well-known/apple-app-site-association",
        "headers": [{ "key": "Content-Type", "value": "application/json" }]
      },
      {
        "source": "**",
        "headers": [{ "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }]
      },
      {
        "source": "**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**/*.@(js|css|woff2|woff|ttf|otf|png|jpg|jpeg|gif|svg|webp|avif|ico)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ],
    "rewrites": [
      { "source": "/api/v1/**", "function": { "functionId": "api", "region": "asia-northeast3" } },
      { "source": "/api/strava/webhook", "function": { "functionId": "stravaWebhook", "region": "asia-northeast3" } },
      { "source": "/og-thumbnail/**", "function": { "functionId": "ogThumbnail", "region": "asia-northeast3" } },
      { "source": "/:lang/design-system.html", "destination": "/design-system.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "hosting": { "port": 5002 },
    "ui": { "enabled": true, "port": 4000 }
  }
}
