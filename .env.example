VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_FUNCTIONS_REGION=asia-northeast3

# Optional local-development switches
VITE_USE_EMULATORS=false
VITE_APPCHECK_RECAPTCHA_SITE_KEY=your-recaptcha-enterprise-site-key

# Optional integrations. Some production routes degrade without these.
VITE_STRAVA_CLIENT_ID=your-strava-client-id
VITE_STRAVA_REDIRECT_URI=http://localhost:5173/strava/callback
VITE_MAPBOX_TOKEN=your-mapbox-public-token
VITE_SEGMENT_TILES_BASE=https://your-static-assets.example.com/segments/tiles
VITE_HEATMAP_BASE=https://your-static-assets.example.com/heat
VITE_SENTRY_DSN=

# Optional local experiments for personal-data recipes.
# The Personal Data API is planned, not a stable public API yet.
VITE_ORIDER_PERSONAL_API_BASE=
