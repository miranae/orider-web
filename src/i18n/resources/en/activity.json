    "glossary": {
      "tss": "Training Stress Score — overall load from intensity × duration. 100 = 1 hr at FTP.",
      "if": "Intensity Factor — NP ÷ FTP. 1.0 means riding at FTP intensity.",
      "work": "Work — total work done this session (kJ). Roughly equals kcal burned.",
      "kjPerHour": "Work per hour (kJ/h) — a measure of average power output intensity.",
      "trimp": "Training Impulse — training load based on heart rate and duration.",
      "recovery": "Recovery time — an estimate of suggested recovery, scaling this session's load against your fitness (higher = harder).",
      "np": "Normalized Power — adjusts for variability to reflect 'felt' average power.",
      "xpower": "xPower (Skiba) — a variability-adjusted power similar to NP (25 s weighted).",
      "vi": "Variability Index — NP ÷ average power. Closer to 1 means steadier pacing.",
      "cp": "Critical Power — the max power sustainable over a long effort (≈FTP).",
      "wprime": "W′ (W-prime) — anaerobic energy capacity available above Critical Power.",
      "matches": "Match — a hard effort well above FTP. Burned like a matchstick, limited in supply.",
      "ef": "Efficiency Factor — NP ÷ average HR. Higher means better aerobic efficiency.",
      "decoupling": "Decoupling — drop in power:HR efficiency in the later half. Lower means better endurance.",
      "sweetSpot": "Sweet Spot — 83–94% FTP. Efficient fitness-building zone for the fatigue cost.",
      "threshold": "Threshold — 95–105% FTP. Around the 1-hour sustainable limit.",
      "vo2max": "VO2max — 106–120% FTP. High intensity that stresses cardiovascular capacity.",
      "anaerobic": "Anaerobic — above 120% FTP. Short, all-out efforts.",
      "fatmax": "FATMAX — the intensity at which fat oxidation rate peaks.",
      "metabolism": "Energy metabolism — estimated fat vs carb burn. Population averages based on RER.",
      "zones": "Intensity zones — distribution of power/HR across intensity bands, each a distinct stimulus.",
      "duration": "Duration — total elapsed time from start to finish (including stops).",
      "avgPower": "Average Power — mean output across the whole ride (zeros included).",
      "maxPower": "Max Power — peak 3-second smoothed output; single spikes removed.",
      "wkgAvg": "Power-to-weight (avg) — average power ÷ body weight (W/kg).",
      "wkgNp": "Power-to-weight (NP) — Normalized Power ÷ body weight (W/kg).",
      "matchesTime": "Match Time — total time spent in hard efforts well above FTP.",
      "longestMatch": "Longest Match — the longest single hard effort above FTP.",
      "avgHr": "Average HR — mean heart rate across the ride (bpm).",
      "maxHr": "Max HR — highest recorded heart rate (bpm).",
      "hrDrift": "HR Drift — rise in HR in the later half vs the first. A fatigue/dehydration/heat signal.",
      "distance": "Distance — total distance traveled.",
      "elevGain": "Elevation Gain — sum of all uphill climbing.",
      "avgSpeed": "Average Speed — mean speed across the ride.",
      "maxSpeed": "Max Speed — highest recorded speed.",
      "avgRpm": "Average Cadence — mean pedal revolutions per minute (rpm).",
      "maxRpm": "Max Cadence — peak pedal revolutions per minute (rpm).",
      "calories": "Calories — estimated energy burned (kcal).",
      "sufferScore": "Cumulative HR-based intensity score. Higher = harder/longer session.",
      "quadrant": "Pedaling quadrants — time share across cadence×torque. High Q4 (low rpm·high torque) = strength-style; high Q1 (high rpm·high power) = high-intensity spinning.",
      "longestZ4": "Longest continuous time ≥91% FTP — threshold endurance.",
      "cadenceConsistency": "Cadence standard deviation. Lower = steadier pedaling.",
      "paceConsistency": "Pace standard deviation. Lower = more even pace.",
      "wPrimeBal": "Time trajectory of W' (anaerobic capacity) balance. Depletes above CP, recharges below (Skiba 2015). A minimum near 0% means nearly maxed out."
    },
    "decoupling": {
      "good": "Aerobic decoupling under 5% — strong durability",
      "warn": "Decoupling 5–10% — late-stage cardiac drift",
